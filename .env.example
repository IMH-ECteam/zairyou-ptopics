# LINE WORKS Developer Console で発行した値
LW_CLIENT_ID=your_client_id_here
LW_CLIENT_SECRET=your_client_secret_here

# Vercel にデプロイ後の実URL + /api/callback に合わせる
LW_REDIRECT_URI=https://your-app.vercel.app/api/callback

# セッション署名用の秘密鍵。生成例: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_string

# （任意）特定ドメイン/組織だけに絞る場合（カンマ区切り）。callback の該当コードも解除すること
# ALLOWED_DOMAINS=@kenje-group.co.jp

# ── アクセス解析 ──────────────────────────────
# （任意）/admin ダッシュボードを見られる管理者メール（カンマ区切り）。
# 未設定なら「ログインできる全社員」が /admin を閲覧可。特定の担当者だけに絞りたい場合に設定する。
# ADMIN_EMAILS=admin@example.com,manager@example.com

# Vercel KV(Upstash Redis) を作成し Connect すると、以下2つは自動で環境変数に追加される。
# 未設定でもアプリは動作し、その場合アクセス記録は Vercel のランタイムログ([access-log])へ出力される。
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
